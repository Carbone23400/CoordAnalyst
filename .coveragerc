[run]
source = coordchem
omit =
    */tests/*
    */test_*
    */__pycache__/*
    */site-packages/*
    App/streamlit_app.py

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    def __str__
    raise NotImplementedError
    if __name__ == .__main__.:
    except ImportError
    pass

[html]
directory = coverage_html